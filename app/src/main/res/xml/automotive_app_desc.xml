<?xml version="1.0" encoding="utf-8"?>
<!--
    template  = Car App Library in-app screens (CarAppService / CarSession)
    notification = MessagingStyle inline-reply via notification (RemoteInput)
    Both are needed for a full messaging experience in Android Auto.
-->
<automotiveApp>
    <uses name="template"/>
    <uses name="notification"/>
</automotiveApp>
